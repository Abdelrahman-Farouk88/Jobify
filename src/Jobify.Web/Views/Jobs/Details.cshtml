@model Jobify.Web.Models.JobDetailsViewModel
@{
    ViewData["Title"] = Model.Job.Title;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <a class="btn btn-outline-secondary btn-sm mb-4" asp-action="Index">&larr; Back to jobs</a>
        
        <article class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4 p-lg-5">
                <header class="mb-4 pb-4 border-bottom border-secondary" style="border-color: var(--j-dim) !important;">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <p class="job-card__meta mb-0">@Model.Job.Category</p>
                        @if (Model.MatchScore > 0)
                        {
                            <span class="match-badge @(Model.MatchSource == "ML" ? "match-badge--ml" : "")">
                                @(Model.MatchSource == "ML" ? "AI MATCH" : "KEYWORD MATCH")
                            </span>
                        }
                    </div>
                    <h1 class="h2 mb-2 fw-bold" style="color: var(--j-ink);">@Model.Job.Title</h1>
                    <p class="text-muted mb-0">@Model.Job.EmployerName &middot; @Model.Job.Location</p>
                    
                    <div class="job-tags mt-3">
                        <span class="badge text-bg-light">@Model.Job.EmploymentType</span>
                        <span class="badge text-bg-secondary">@Model.Job.ExperienceLevel</span>
                        <span class="badge text-bg-primary">Posted @Model.Job.PostedAtUtc.ToLocalTime().ToString("MMM d")</span>
                    </div>
                </header>

                @if (Model.MatchScore > 0)
                {
                    <div class="mb-4 p-3 rounded" style="background: var(--j-cyan-dim); border: 1px solid var(--j-border-v);">
                        <div class="d-flex align-items-center gap-3">
                            <div class="match-ring" data-score="@(Model.MatchScore ?? 0)">
                                <div class="match-ring__inner">
                                    <div class="match-ring__score">@(Math.Round((Model.MatchScore) ?? 0))%</div>
                                </div>
                            </div>
                            <div>
                                <h3 class="h6 text-uppercase fw-bold mb-1" style="color: var(--j-cyan);">Match Score</h3>
                                @if (Model.MatchReasons != null && Model.MatchReasons.Any())
                                {
                                    <p class="small text-muted mb-0">@string.Join(" &middot; ", Model.MatchReasons)</p>
                                }
                            </div>
                        </div>
                    </div>
                }

                <div class="mb-4">
                    <h2 class="h6 text-uppercase text-muted fw-bold mb-3">Required Skills</h2>
                    <p class="fs-5">@Model.Job.RequiredSkills</p>
                </div>

                <div class="mb-5">
                    <h2 class="h6 text-uppercase text-muted fw-bold mb-3">Job Description</h2>
                    <div style="line-height: 1.8;">
                        @Html.Raw(Model.Job.Description.Replace("\n", "<br />"))
                    </div>
                </div>

                <div class="d-grid gap-2 d-sm-flex">
                    @if (Model.HasApplied)
                    {
                        <button class="btn btn-outline-success" disabled>Already Applied</button>
                    }
                    else if (User.IsInRole("JobSeeker"))
                    {
                        if (Model.MatchScore < 50)
                        {
                            <div>
                                <button class="btn btn-outline-danger w-100" disabled title="Match score too low">Match Below 50% — Cannot Apply</button>
                                <p class="text-danger small mt-2 mb-0">Your profile match is below the 50% threshold. Update your skills to apply.</p>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-cta" asp-action="Apply" asp-route-id="@Model.Job.Id">Apply Now</a>
                        }
                    }
                    else if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a class="btn btn-outline-primary" asp-area="Identity" asp-page="/Account/Login">Log in to apply</a>
                    }
                </div>
            </div>
        </article>
    </div>
</div>
