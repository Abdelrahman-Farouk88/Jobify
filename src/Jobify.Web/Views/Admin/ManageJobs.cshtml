@model IEnumerable<Jobify.Web.Models.JobPosting>
@{
    ViewData["Title"] = "Manage Jobs";
}

<div class="jobify-page-hero mb-4">
    <p class="text-muted small text-uppercase fw-bold mb-1">Root Access</p>
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h1 class="h3 mb-0 fw-semibold">Manage Jobs</h1>
    </div>
    <p class="text-muted">Review active jobs, detect anomalies, and remove fake postings.</p>
</div>

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back to Dashboard</a>
</div>

<div class="card shadow-sm border-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table  table-hover mb-0 align-middle">
            <thead class="">
                <tr>
                    <th scope="col" class="ps-4">Title</th>
                    <th scope="col">Employer</th>
                    <th scope="col">Status</th>
                    <th scope="col">Posted Date</th>
                    <th scope="col" class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var job in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium text-white">@job.Title</td>
                            <td>@job.EmployerName</td>
                            <td>
                                @if (job.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-muted small">@job.PostedAtUtc.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteJob" method="post" class="d-inline" onsubmit="return confirm('WARNING: Are you sure you want to permanently delete this job posting?');">
                                    <input type="hidden" name="id" value="@job.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Fake Job">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                            <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                                        </svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No jobs available in the system.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
