@model Jobify.Web.Models.AdminReportsViewModel
@{
    ViewData["Title"] = "Global Telemetry";
}

<div class="jobify-page-hero mb-4">
    <p class="text-muted small text-uppercase fw-bold mb-1">Root Access</p>
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 fw-semibold">Global Telemetry</h1>
    </div>

<section class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4 p-lg-5">
        <h2 class="h5 mb-4 fw-semibold text-primary">Engagement Metrics</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-muted small text-uppercase mono mb-1">Total Applications</div>
                <div class="h2 mb-0" style="color: var(--j-cyan);">@Model.Applications</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small text-uppercase mono mb-1">Total Jobs</div>
                <div class="h2 mb-0" style="color: var(--j-violet);">@Model.Jobs</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small text-uppercase mono mb-1">System Health</div>
                <div class="h2 mb-0 text-success mono">NOMINAL</div>
            </div>
        </div>
    </div>
</section>

<section class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4 p-lg-5">
        <h2 class="h5 mb-4 fw-semibold text-primary">Jobs by Category</h2>
        @if (Model.JobCategoryCounts.Count == 0)
        {
            <div class="empty-state py-4">
                <p class="mb-0">No category data available.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var count in Model.JobCategoryCounts.OrderByDescending(x => x.Count))
                {
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between align-items-center p-3 border rounded border-secondary" style="border-color: var(--j-dim) !important; background: rgba(2,4,8,0.3);">
                            <span class="fw-medium text-white">@count.Label</span>
                            <span class="badge text-bg-primary fs-6 mono">@count.Count</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<div class="mt-4">
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">&larr; Return to Root Access</a>
</div>