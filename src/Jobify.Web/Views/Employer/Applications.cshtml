@model IReadOnlyList<Jobify.Web.Models.JobApplication>
@{
    var job = (Jobify.Web.Models.JobPosting)ViewBag.Job;
    ViewData["Title"] = $"Applications for {job.Title}";
}

<section class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4 p-lg-5">
        <p class="text-muted fw-bold small text-uppercase mb-1">@job.Category</p>
        <h1 class="h3 mb-2 fw-semibold text-primary">@job.Title</h1>
        <p class="text-muted mb-0">@job.Location &middot; @job.EmploymentType</p>
    </div>
</section>

<section class="card shadow-sm border-0">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3" style="border-color: var(--j-dim) !important;">
            <h2 class="h5 mb-0 fw-semibold text-primary">Candidate Pipeline (@Model.Count)</h2>
            <div class="btn-group btn-group-sm">
                <a asp-action="Applications" asp-route-jobId="@job.Id" asp-route-filterShortlisted="false" class="btn btn-outline-primary @(ViewBag.FilterShortlisted == false ? "active" : "")">All</a>
                <a asp-action="Applications" asp-route-jobId="@job.Id" asp-route-filterShortlisted="true" class="btn btn-outline-warning @(ViewBag.FilterShortlisted == true ? "active" : "")">Shortlisted</a>
            </div>
        </div>
        @if (Model.Count == 0)
        {
            <div class="empty-state py-4">
                <p class="mb-0">Pipeline empty. Wait for candidates to discover this mission.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var application in Model)
                {
                    <div class="col-12">
                        <div class="application-card">
                            <div class="d-flex justify-content-between flex-wrap gap-2 mb-2">
                                <div>
                                    <div class="fw-bold text-white">@application.ApplicantName</div>
                                    <div class="small text-muted mono">Applied @application.AppliedAtUtc.ToLocalTime().ToString("MMM d, yyyy 'at' HH:mm")</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    @if(ViewBag.MatchScores != null && ViewBag.MatchScores.ContainsKey(application.Id))
                                    {
                                        <span class="badge text-bg-info">@(Math.Round((decimal)ViewBag.MatchScores[application.Id]))% Match</span>
                                    }
                                    @if(application.IsShortlisted) {
                                        <span class="badge text-bg-warning">Shortlisted</span>
                                    }
                                    <span class="status-led status-led--@application.Status.ToString().ToLowerInvariant()"></span>
                                    <span class="badge status-badge--@application.Status.ToString().ToLowerInvariant()">@application.Status</span>
                                    <form method="post" asp-action="ToggleShortlist" class="m-0 ms-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="applicationId" value="@application.Id" />
                                        <input type="hidden" name="currentFilterState" value="@(ViewBag.FilterShortlisted.ToString().ToLowerInvariant())" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning p-1" title="@(application.IsShortlisted ? "Remove from shortlist" : "Add to shortlist")">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16" style="@(application.IsShortlisted ? "" : "opacity: 0.3;")">
                                              <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <p class="mb-3 text-muted">@application.CoverLetter</p>
                            @if (!string.IsNullOrWhiteSpace(application.ResumeUrl))
                            {
                                <div class="mb-3">
                                    <a href="@application.ResumeUrl" target="_blank" class="btn btn-outline-secondary btn-sm">Download CV</a>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(application.AssessmentAnswer))
                            {
                                <div class="mb-3 p-3 rounded" style="background-color: var(--j-bg); border: 1px solid var(--j-dim);">
                                    <h6 class="text-warning mb-1 small">Assessment Answer:</h6>
                                    <p class="mb-0 text-white small">@application.AssessmentAnswer</p>
                                </div>
                            }

                            <hr class="neon-hr my-3" />
                            <form method="post" asp-action="ReviewApplication" class="row g-2 align-items-end">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="applicationId" value="@application.Id" />
                                <div class="col-md-3">
                                    <label class="form-label small">Status Override</label>
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (var status in Enum.GetValues<Jobify.Web.Models.ApplicationStatus>())
                                        {
                                            if (application.Status == status)
                                            {
                                                <option value="@status" selected>@status</option>
                                            }
                                            else
                                            {
                                                <option value="@status">@status</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label small">Reviewer notes</label>
                                    <input name="notes" class="form-control form-control-sm" value="@application.ReviewerNotes" placeholder="Optional private feedback" />
                                </div>
                                <div class="col-md-2 d-grid">
                                    <button class="btn btn-primary btn-sm" type="submit">Execute</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<div class="mt-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="Dashboard">&larr; Return to dashboard</a>
</div>
