@model Jobify.Web.Models.JobPostingInputModel
@{
    ViewData["Title"] = "Post a Job";
}

<section class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4 p-lg-5">
        <p class="text-muted small text-uppercase fw-bold mb-1">Employer Dashboard</p>
        <h1 class="h3 mb-3 fw-semibold">Initialize new mission</h1>

        <form method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="col-md-6">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="e.g. Junior .NET Developer" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" placeholder="e.g. Software Development" />
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" placeholder="Remote, Hybrid, On-site" />
                <span asp-validation-for="Location" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EmploymentType" class="form-label"></label>
                <input asp-for="EmploymentType" class="form-control" placeholder="Full-time, Internship" />
                <span asp-validation-for="EmploymentType" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ExperienceLevel" class="form-label"></label>
                <input asp-for="ExperienceLevel" class="form-control" placeholder="Entry-level, Student" />
                <span asp-validation-for="ExperienceLevel" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="RequiredSkills" class="form-label"></label>
                <input asp-for="RequiredSkills" class="form-control" placeholder="C#, ASP.NET Core, SQL" />
                <span asp-validation-for="RequiredSkills" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Describe the role, responsibilities, and what you're looking for"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-12 mt-4 pt-3 border-top" style="border-color: var(--j-dim) !important;">
                <h4 class="h5 mb-3 fw-semibold">Optional Assessment</h4>
                <p class="text-muted small">Add a required question for applicants. This helps automatically filter candidates.</p>
            </div>
            <div class="col-12">
                <label asp-for="AssessmentPrompt" class="form-label">Assessment Prompt / Question</label>
                <input asp-for="AssessmentPrompt" class="form-control" placeholder="e.g. Provide a link to a CodePen, or answer: Why do you want to work here?" />
                <span asp-validation-for="AssessmentPrompt" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="AssessmentExpectedAnswer" class="form-label">Expected Answer / Keyword (Optional)</label>
                <input asp-for="AssessmentExpectedAnswer" class="form-control" placeholder="e.g. Yes, or a specific keyword" />
                <span asp-validation-for="AssessmentExpectedAnswer" class="text-danger small"></span>
            </div>
            <div class="col-12 d-flex gap-2 pt-3 mt-4 border-top" style="border-color: var(--j-dim) !important;">
                <button class="btn btn-primary" type="submit">Post Job</button>
                <a class="btn btn-outline-secondary" asp-action="Dashboard">Abort</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
